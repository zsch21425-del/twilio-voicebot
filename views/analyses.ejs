<%- include('partials/header', { pageTitle, configStatus }) %>

<section class="card">
  <div class="card-head">
    <h2>Goal Progress</h2>
    <small>
      Mode: <strong><%= alpacaMode %></strong> ·
      <% if (execState.pausedAt) { %>
        <span class="badge badge-off">Auto-exec PAUSED</span>
      <% } else { %>
        <span class="badge badge-on">Auto-exec active</span>
      <% } %>
    </small>
  </div>
  <%
    const goalPct = execState.goal > 0 ? Math.min(100, (currentEquity / execState.goal) * 100) : 0;
    const gain = currentEquity - execState.deposit;
  %>
  <p>
    Equity <strong>$<%= currentEquity.toFixed(2) %></strong>
    from deposit <strong>$<%= Number(execState.deposit).toFixed(2) %></strong>
    (<%= gain >= 0 ? '+' : '' %>$<%= gain.toFixed(2) %>)
    → goal <strong>$<%= Number(execState.goal).toLocaleString() %></strong>
    (<%= goalPct.toFixed(3) %>%)
  </p>
  <div style="background:#1e2631;border-radius:6px;height:14px;overflow:hidden">
    <div style="background:#3ecf8e;height:100%;width:<%= goalPct %>%"></div>
  </div>
  <p>
    Current per-order cap: <strong>$<%= Number(currentCap).toFixed(2) %></strong>
    (rises $<%= Number(execState.tierStep).toFixed(0) %> for every $<%= Number(execState.tierStep).toFixed(0) %> of equity gain)
  </p>

  <div class="actions" style="display:flex;gap:8px;flex-wrap:wrap">
    <% if (execState.pausedAt) { %>
      <form method="post" action="/portfolio/resume"><button type="submit" class="primary">Resume auto-exec</button></form>
    <% } else { %>
      <form method="post" action="/portfolio/pause"><button type="submit" class="danger">PAUSE auto-exec now</button></form>
    <% } %>
    <% if (!execState.liveAckAt && alpacaMode === 'live') { %>
      <form method="post" action="/portfolio/ack-live" onsubmit="return confirm('Acknowledge LIVE mode with real money?')">
        <button type="submit">Acknowledge live mode</button>
      </form>
    <% } %>
    <% if (notifierConfigured) { %>
      <form method="post" action="/portfolio/test-alert">
        <button type="submit">Send test alert</button>
      </form>
    <% } %>
  </div>

  <p class="hint">
    Trading alerts: <%= notifierConfigured ? 'ENABLED — you will be notified on AI trades, failures, and pauses.' : 'not configured (set TRADING_ALERTS_ENABLED, TRADING_ALERTS_PHONE, and Twilio creds).' %>
  </p>

  <% if (alpacaMode === 'live' && !execState.liveAckAt) { %>
    <div class="alert alert-warn">
      <strong>LIVE mode without acknowledgment.</strong> Flipping ALPACA_BASE_URL to live means real trades. Click "Acknowledge live mode" when you are sure.
    </div>
  <% } %>
</section>

<section class="card">
  <div class="card-head">
    <h2>Execution Settings</h2>
  </div>
  <form method="post" action="/portfolio/execution" class="stacked">
    <label>Starting deposit (USD)
      <input name="deposit" type="number" step="0.01" min="1" value="<%= execState.deposit %>" />
    </label>
    <label>Long-term goal (USD)
      <input name="goal" type="number" step="1" min="1" value="<%= execState.goal %>" />
    </label>
    <label>Tier step (cap raises by this for every this much equity gain)
      <input name="tier_step" type="number" step="1" min="1" value="<%= execState.tierStep %>" />
    </label>
    <label>Floor cap (minimum per-order notional)
      <input name="floor_cap" type="number" step="1" min="1" value="<%= execState.floorCap %>" />
    </label>
    <button type="submit">Save execution settings</button>
  </form>
</section>

<section class="card">
  <div class="card-head">
    <h2>Run Analysis</h2>
    <small>
      Model: <code>claude-opus-4-7</code>
      <%= strategistConfigured ? '' : ' (ANTHROPIC_API_KEY missing)' %>
    </small>
  </div>
  <% if (!strategistConfigured) { %>
    <div class="alert alert-warn">Set <code>ANTHROPIC_API_KEY</code> in <code>.env</code> to enable analyses.</div>
  <% } %>
  <form method="post" action="/portfolio/analyze">
    <label>Optional extra instruction for this run
      <input name="instruction" maxlength="1000" placeholder="e.g. Focus on covered-call candidates this week" />
    </label>
    <button type="submit" class="primary" <%= strategistConfigured ? '' : 'disabled' %>>Analyze &amp; auto-execute</button>
  </form>
  <p class="hint">
    Claude returns recommendations as structured JSON. Each is routed through the auto-exec policy:
    under the cap → submitted immediately, above the cap → queued on the Portfolio page.
  </p>
</section>

<section class="card">
  <div class="card-head">
    <h2>Strategist Settings</h2>
  </div>
  <form method="post" action="/portfolio/settings" class="stacked">
    <label>Investor profile (paste your answers to the profile questions; used as system-prompt context)
      <textarea name="profile" rows="8" maxlength="10000"><%= settings.profile || '' %></textarea>
    </label>
    <label>Master prompt override (leave blank to use the built-in default)
      <textarea name="master_prompt" rows="16" maxlength="20000" placeholder="<%= defaultMasterPrompt.slice(0, 200) %>..."><%= settings.masterPrompt || '' %></textarea>
    </label>
    <button type="submit">Save settings</button>
  </form>
  <details>
    <summary>Show default master prompt</summary>
    <pre style="white-space: pre-wrap"><%= defaultMasterPrompt %></pre>
  </details>
</section>

<section class="card">
  <div class="card-head">
    <h2>Recent Analyses</h2>
  </div>
  <% if (!analyses.length) { %>
    <p>No analyses yet.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>When</th>
            <th>Source</th>
            <th>Model</th>
            <th>Tokens (in/out)</th>
            <th>Cache (read/write)</th>
            <th>Preview</th>
          </tr>
        </thead>
        <tbody>
          <% analyses.forEach((a) => { %>
            <tr>
              <td><a href="/portfolio/analyses/<%= a.id %>">#<%= a.id %></a></td>
              <td><%= new Date(a.created_at).toLocaleString() %></td>
              <td><%= a.source %></td>
              <td><%= a.model %></td>
              <td><%= a.input_tokens || 0 %> / <%= a.output_tokens || 0 %></td>
              <td><%= a.cache_read_input_tokens || 0 %> / <%= a.cache_creation_input_tokens || 0 %></td>
              <td>
                <% if (a.error_message) { %>
                  <span class="badge badge-off"><%= a.error_message.slice(0, 80) %></span>
                <% } else { %>
                  <%= (a.preview || '').slice(0, 120) %><%= (a.preview || '').length > 120 ? '…' : '' %>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>

<%- include('partials/header', { pageTitle, configStatus }) %>
<section class="card">
  <div class="card-head">
    <h2>Scheduled Jobs</h2>
    <a class="btn-link" href="/">+ New schedule</a>
  </div>

  <% if (!schedules.length) { %>
    <p>No schedules yet. <a href="/">Create your first schedule</a>.</p>
  <% } else { %>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ID</th>
            <th>Phone</th>
            <th>Type</th>
            <th>Message</th>
            <th>Base Time</th>
            <th>Next Run</th>
            <th>Last Run</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% schedules.forEach((job) => { %>
            <tr>
              <td><%= job.id %></td>
              <td><%= job.phone_number %></td>
              <td><%= job.schedule_type %></td>
              <td class="msg-cell" title="<%= job.message_text %>">
                <%= job.message_text.length > 60 ? job.message_text.slice(0, 60) + '…' : job.message_text %>
              </td>
              <td><%= new Date(job.scheduled_at).toLocaleString() %></td>
              <td>
                <% if (job.next_run_at) { %>
                  <%= new Date(job.next_run_at).toLocaleString() %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>
              <td>
                <% if (job.last_run_at) { %>
                  <%= new Date(job.last_run_at).toLocaleString() %>
                <% } else { %>
                  &mdash;
                <% } %>
              </td>
              <td>
                <span class="badge <%= job.enabled ? 'badge-on' : 'badge-off' %>">
                  <%= job.enabled ? 'Enabled' : 'Disabled' %>
                </span>
              </td>
              <td class="actions">
                <form method="post" action="/schedules/<%= job.id %>/run-now" onsubmit="return confirm('Place this call now?')">
                  <button type="submit" class="primary">Run now</button>
                </form>
                <form method="post" action="/schedules/<%= job.id %>/toggle">
                  <button type="submit"><%= job.enabled ? 'Disable' : 'Enable' %></button>
                </form>
                <form method="post" action="/schedules/<%= job.id %>/delete" onsubmit="return confirm('Delete this schedule?')">
                  <button type="submit" class="danger">Delete</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
<%- include('partials/footer') %>

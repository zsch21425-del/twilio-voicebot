<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Twilio Voicebot</title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <h1>Twilio Voicebot</h1>
      <nav>
        <a href="/">Create Schedule</a>
        <a href="/schedules">Scheduled Jobs</a>
        <a href="/logs">Call Logs</a>
        <a href="/portfolio">Portfolio</a>
      </nav>
    </div>
  </header>
  <main class="container">
    <% if (typeof configStatus !== 'undefined' && (!configStatus.twilio || !configStatus.google)) { %>
      <div class="alert alert-warn">
        <strong>Setup incomplete:</strong>
        <% if (!configStatus.twilio) { %>
          <span>Twilio credentials missing &mdash; calls will be skipped.</span>
        <% } %>
        <% if (!configStatus.google) { %>
          <span>Google TTS credentials missing &mdash; audio generation will fail.</span>
        <% } %>
        See <code>.env.example</code>.
      </div>
    <% } %>

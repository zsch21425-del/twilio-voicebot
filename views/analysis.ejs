<%- include('partials/header', { pageTitle, configStatus }) %>

<section class="card">
  <div class="card-head">
    <h2>Analysis #<%= analysis.id %></h2>
    <small>
      <%= new Date(analysis.created_at).toLocaleString() %> ·
      <%= analysis.model %> ·
      <%= analysis.source %>
    </small>
  </div>
  <p>
    Tokens — input: <%= analysis.input_tokens || 0 %>,
    output: <%= analysis.output_tokens || 0 %>,
    cache read: <%= analysis.cache_read_input_tokens || 0 %>,
    cache write: <%= analysis.cache_creation_input_tokens || 0 %>
  </p>

  <% if (analysis.error_message) { %>
    <div class="alert alert-warn"><%= analysis.error_message %></div>
  <% } else { %>
    <h3>Strategist response</h3>
    <pre style="white-space: pre-wrap"><%= analysis.response_text || '' %></pre>

    <% if (analysis.thinking_text) { %>
      <details>
        <summary>Summarized thinking</summary>
        <pre style="white-space: pre-wrap"><%= analysis.thinking_text %></pre>
      </details>
    <% } %>
  <% } %>

  <details>
    <summary>Snapshot JSON</summary>
    <pre style="white-space: pre-wrap; font-size: 12px"><%= analysis.snapshot_json %></pre>
  </details>

  <p><a href="/portfolio/analyses">← All analyses</a></p>
</section>

<%- include('partials/footer') %>

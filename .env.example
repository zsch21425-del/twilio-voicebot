PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
GOOGLE_APPLICATION_CREDENTIALS=./google-key.json
# Alternative for PaaS deploys: paste the whole service-account JSON (or base64 of it)
# into this var. On start, write-gcloud-key.js writes it to ./google-key.json.
# Leave blank for local dev when you have the key file on disk.
GOOGLE_CREDENTIALS_JSON=
GOOGLE_TTS_LANGUAGE=en-US
GOOGLE_TTS_VOICE=en-US-Neural2-C
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Alpaca broker API (https://alpaca.markets). Start on paper:
#   ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Switch to live only when you mean it:
#   ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Auto-execution policy. Orders with notional <= this value execute
# immediately; anything above is queued for manual approval. Set to 0
# to require approval for every order.
ALPACA_AUTO_EXECUTE_MAX_USD=500
# Safety kill switch. Must be exactly "true" to allow any auto-execution,
# even on paper. Any other value disables auto-exec entirely.
ALPACA_AUTO_EXECUTE_ENABLED=false

# Anthropic API key for the AI strategist (optional; snapshot JSON
# still works without it).
ANTHROPIC_API_KEY=

# Nightly analysis schedule (cron in the given timezone).
# Default: 9:30 AM US/Eastern, weekdays (market open).
# Set PORTFOLIO_ANALYSIS_CRON="" to disable.
PORTFOLIO_ANALYSIS_CRON=30 9 * * 1-5
PORTFOLIO_ANALYSIS_TIMEZONE=America/New_York
